import random

def play_hangman():
    # Step 1: Predefined list of words
    words = ["python", "hangman", "computer", "keyboard", "science"]

    # Step 2: Randomly pick one word from the list
    word = random.choice(words)

    # Step 3: Track guessed letters and remaining attempts
    guessed_letters = []
    max_attempts = 6
    wrong_attempts = 0

    print("Welcome to Hangman!")
    print(f"The word has {len(word)} letters. You have {max_attempts} wrong guesses allowed.\n")

    # Step 4: Main game loop
    while wrong_attempts < max_attempts:
        # Build the display word: show guessed letters, hide the rest with "_"
        display_word = ""
        for letter in word:
            if letter in guessed_letters:
                display_word += letter + " "
            else:
                display_word += "_ "

        print(display_word)
        print(f"Wrong guesses remaining: {max_attempts - wrong_attempts}")

        # Check win condition: every letter in word has been guessed
        if "_" not in display_word:
            print("\n🎉 Congratulations! You guessed the word:", word)
            break

        # Step 5: Get player input
        guess = input("Guess a letter: ").lower().strip()

        # Basic input validation
        if len(guess) != 1 or not guess.isalpha():
            print("Please enter a single letter.\n")
            continue

        if guess in guessed_letters:
            print("You already guessed that letter. Try another.\n")
            continue

        guessed_letters.append(guess)

        # Step 6: Check if guess is correct
        if guess in word:
            print("Correct!\n")
        else:
            wrong_attempts += 1
            print(f"Wrong! ({wrong_attempts}/{max_attempts} wrong guesses)\n")

    # Step 7: Handle loss condition (loop ended due to too many wrong guesses)
    else:
        print(f"\n💀 Game over! You've used all {max_attempts} wrong guesses.")
        print(f"The word was: {word}")


if __name__ == "__main__":
    play_hangman()
